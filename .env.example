# ============================================
# DARKI — API Keys Configuration
# ============================================
# Copy this file to .env and fill in your API keys.
# Get your free keys from:
#   Google AI Studio:  https://aistudio.google.com/apikey
#   Groq Console:      https://console.groq.com/keys
#   Cerebras Cloud:    https://cloud.cerebras.ai/
# ============================================

# Google Gemini (Required — primary provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Required — fast utility + fallback)
GROQ_API_KEY=your_groq_api_key_here

# Cerebras (Optional — ultra-fast fallback)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# SambaNova (Optional — Meta-Llama-3.1-405B)
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Mistral AI (Optional — Codestral coding model)
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere (Optional — Command R+ web scraping/doc model)
COHERE_API_KEY=your_cohere_api_key_here

# ============================================
# Optional — SMTP Credentials for Background Emailing
# ============================================
# Configure these if you use Outlook New or want emails to be sent
# completely in the background without launching Outlook.
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_here

# ============================================
# Local AI Integration — Ollama (Offline Mode)
# ============================================
# Install Ollama from https://ollama.com and run your desired model.
# Ollama URL (Default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
# Ollama model name (e.g., llama3.2, deepseek-r1:8b, qwen2.5:7b)
OLLAMA_MODEL=llama3.2


