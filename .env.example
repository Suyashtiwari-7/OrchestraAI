# ============================================
# OrchestraAI — API Keys Configuration
# ============================================
# Copy this file to .env and fill in your API keys.
# Get your free keys from:
#   Google AI Studio:  https://aistudio.google.com/apikey
#   Groq Console:      https://console.groq.com/keys
#   Cerebras Cloud:    https://cloud.cerebras.ai/
# ============================================

# Google Gemini (Required — primary provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Required — fast utility + fallback)
GROQ_API_KEY=your_groq_api_key_here

# Cerebras (Optional — ultra-fast fallback)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# SambaNova (Optional — Meta-Llama-3.1-405B)
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Mistral AI (Optional — Codestral coding model)
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere (Optional — Command R+ web scraping/doc model)
COHERE_API_KEY=your_cohere_api_key_here
